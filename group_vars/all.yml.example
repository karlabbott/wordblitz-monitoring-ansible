# Azure subscription where monitoring resources will be created
azure_subscription_id: "your-subscription-id-here"

# Resource group containing the VMs to monitor
azure_resource_group: "your-resource-group"

# Azure region
azure_location: "eastus"

# Log Analytics Workspace name
law_name: "your-law-name"

# Managed Grafana instance name
grafana_name: "your-grafana-name"

# Database VM
db_vm_name: "your-db-vm-name"
db_vm_host: "1.2.3.4"

# Application VM
app_vm_name: "your-app-vm-name"
app_vm_host: "5.6.7.8"

# SSH username for both VMs
ssh_user: "azureuser"

# Computer names as they appear in Log Analytics
# IMPORTANT: Syslog and Perf tables often report different computer names.
# Syslog typically uses the short hostname (e.g., "myvm"), while Perf uses
# the FQDN (e.g., "myvm.example.com"). Run these queries after initial data
# collection to discover the correct values:
#   Syslog: az monitor log-analytics query --workspace <id> --analytics-query "Syslog | distinct Computer"
#   Perf:   az monitor log-analytics query --workspace <id> --analytics-query "Perf | distinct Computer"
db_vm_computer_name: "your-db-hostname"
app_vm_computer_name: "your-app-short-hostname"
app_vm_perf_computer_name: "your-app-fqdn"

# Perf counter sampling interval in seconds
perf_sampling_interval: 60

# Syslog facilities to collect
syslog_facilities:
  - auth
  - authpriv
  - daemon
  - kern
  - syslog
  - user
  - local0
  - local1
  - local2
  - local3

# Syslog log levels to collect
syslog_log_levels:
  - Debug
  - Info
  - Notice
  - Warning
  - Error
  - Critical
  - Alert
  - Emergency

# Chaos scenario delay (minutes after playbook completes)
chaos_delay_minutes: 1

# PostgreSQL max_connections during chaos (default is 100; low value starves the app)
chaos_max_connections: 30
